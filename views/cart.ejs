<%- include('layout/header') %>

<div class="container mt-4 animate-fade">
  <h3 class="fw-bold mb-4" style="padding-left: 1rem; border-left: 4px solid #6366f1;">
    <i class="bi bi-cart3 me-2"></i> ตะกร้าสินค้า
  </h3>

  <% if (cart.length === 0) { %>
    <div class="empty-state">
      <i class="bi bi-cart-x"></i>
      <p>ตะกร้าสินค้าว่าง</p>
      <a href="/products" class="btn btn-primary">
        <i class="bi bi-grid me-1"></i> เลือกซื้อสินค้า
      </a>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th>สินค้า</th>
            <th>ราคา</th>
            <th>จำนวน</th>
            <th>รวม</th>
            <th class="text-end"></th>
          </tr>
        </thead>
        <tbody>
          <% cart.forEach(item => { %>
            <tr>
              <td><strong><%= item.name %></strong></td>
              <td>฿<%= item.price.toFixed(2) %></td>
              <td>
                <form action="/cart/update/<%= item.productId %>" method="POST" class="d-flex align-items-center gap-1">
                  <input type="number" name="quantity" class="form-control form-control-sm" value="<%= item.quantity %>" min="0" max="<%= item.stock %>" style="width: 65px; text-align: center;">
                  <button type="submit" class="btn btn-sm btn-outline-primary" title="อัปเดต">
                    <i class="bi bi-arrow-clockwise"></i>
                  </button>
                </form>
              </td>
              <td class="fw-bold">฿<%= (item.price * item.quantity).toFixed(2) %></td>
              <td class="text-end">
                <form action="/cart/remove/<%= item.productId %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-outline-danger" title="ลบ">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="text-end fw-bold fs-5">ยอดรวมทั้งหมด:</td>
            <td class="fw-bold fs-4" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
              ฿<%= total.toFixed(2) %>
            </td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mt-4 p-4 rounded-4" style="background: var(--bg-card); border: 1px solid var(--border-glass);">
      <div>
        <small class="text-muted">ยอดเงินคงเหลือของคุณ</small>
        <h4 class="fw-bold mb-0" style="color: var(--accent);">฿<%= user.balance.toLocaleString() %></h4>
      </div>
      <div class="d-flex gap-2">
        <% if (total > user.balance) { %>
          <div class="d-flex align-items-center gap-2">
            <span class="text-danger"><i class="bi bi-exclamation-circle"></i> ยอดเงินไม่เพียงพอ</span>
            <a href="/topup" class="btn btn-warning"><i class="bi bi-wallet2 me-1"></i> เติมเงิน</a>
          </div>
        <% } else { %>
          <form action="/cart/checkout" method="POST">
            <button type="submit" class="btn btn-success btn-lg px-4">
              <i class="bi bi-credit-card me-2"></i> ชำระเงิน
            </button>
          </form>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<%- include('layout/footer') %>
