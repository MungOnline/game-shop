<%- include('../layout/header') %>

<div class="container mt-4 animate-fade">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card p-4">
        <h4 class="fw-bold mb-4" style="padding-left: 1rem; border-left: 4px solid #6366f1;">
          <i class="bi bi-<%= product ? 'pencil' : 'plus-circle' %> me-2"></i>
          <%= product ? 'แก้ไขสินค้า' : 'เพิ่มสินค้าใหม่' %>
        </h4>

        <form action="/admin/products/<%= product ? 'edit/' + product._id : 'create' %>" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">ชื่อสินค้า</label>
            <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" placeholder="ชื่อสินค้า" required>
          </div>
          <div class="mb-3">
            <label class="form-label">รายละเอียด</label>
            <textarea name="description" class="form-control" rows="3" placeholder="รายละเอียดสินค้า"><%= product ? product.description : '' %></textarea>
          </div>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">ราคา (บาท)</label>
              <input type="number" name="price" class="form-control" step="0.01" value="<%= product ? product.price : '' %>" placeholder="0.00" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">สต็อก (ไม่รวมรหัส)</label>
              <input type="number" name="stock" class="form-control" value="<%= product ? product.stock : '0' %>" placeholder="0">
            </div>
            <div class="col-md-4">
              <label class="form-label">หมวดหมู่</label>
              <input type="text" name="category" class="form-control" value="<%= product ? product.category : 'ทั่วไป' %>" placeholder="หมวดหมู่">
            </div>
          </div>
          <% if (!product) { %>
            <div class="mb-3 mt-3">
              <label class="form-label">รหัสสินค้า (1 บรรทัดต่อ 1 รหัส)</label>
              <textarea name="codes" class="form-control" rows="5" placeholder="CODE-XXX-XXX&#10;CODE-YYY-YYY"></textarea>
              <small class="text-muted">ไม่ต้องใส่ก็ได้ สามารถเพิ่มทีหลัง</small>
            </div>
          <% } %>
          <div class="mb-3 mt-3">
            <label class="form-label">รูปสินค้า</label>
            <input type="file" name="image" class="form-control" accept="image/*">
            <% if (product) { %>
              <small class="text-muted">เว้นว่างไว้ใช้รูปเดิม</small>
            <% } %>
          </div>
          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary px-4">
              <i class="bi bi-<%= product ? 'check-lg' : 'plus-lg' %> me-1"></i>
              <%= product ? 'บันทึก' : 'เพิ่มสินค้า' %>
            </button>
            <a href="/admin/products" class="btn btn-outline-light px-4">ยกเลิก</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../layout/footer') %>
