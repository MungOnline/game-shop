<%- include('layout/header') %>

<div class="container mt-4 animate-fade">
  <div class="card p-4">
    <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
      <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-receipt me-2"></i> รายละเอียดออเดอร์</h4>
        <small class="text-muted">วันที่: <%= new Date(order.createdAt).toLocaleString('th-TH') %></small>
      </div>
      <div>
        <% if (order.status === 'completed') { %>
          <span class="badge bg-success fs-6 px-3 py-2">ชำระเงินสำเร็จ</span>
        <% } else if (order.status === 'pending') { %>
          <span class="badge bg-warning">รอดำเนินการ</span>
        <% } else { %>
          <span class="badge bg-danger">ยกเลิก</span>
        <% } %>
      </div>
    </div>

    <hr style="border-color: var(--border-glass);">

    <h5 class="mb-3" style="color: var(--accent);">
      <i class="bi bi-key me-2"></i> รหัสสินค้าของคุณ
    </h5>

    <% order.items.forEach(item => { %>
      <div class="code-box">
        <div class="d-flex justify-content-between align-items-center">
          <strong><%= item.productName %></strong>
          <span class="text-muted small">฿<%= item.price.toFixed(2) %></span>
        </div>
        <code class="d-block mt-2"><%= item.code %></code>
      </div>
    <% }) %>

    <hr style="border-color: var(--border-glass);">

    <div class="d-flex justify-content-between align-items-center">
      <span class="fw-bold fs-5">ยอดรวมทั้งสิ้น</span>
      <span class="fw-bold fs-3 price-tag">฿<%= order.total.toFixed(2) %></span>
    </div>
  </div>
</div>

<%- include('layout/footer') %>
